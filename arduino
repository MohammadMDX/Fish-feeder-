#include <Servo.h>
#include <Wire.h>
#include <LiquidCrystal_I2C.h>

// Initialize Servo
Servo myservo;
const int servoPin = 9;

// Initialize LCD
LiquidCrystal_I2C lcd(0x27, 16, 2);

void setup() {
  myservo.attach(servoPin);  // Attach the servo
  lcd.init();                // Initialize LCD
  lcd.backlight();           // Turn on LCD backlight
}

void loop() {
  lcd.clear();
  lcd.setCursor(3, 0);
  lcd.print("Feeding Time!");

  // Countdown before feeding
  for (int i = 10; i >= 0; i--) {
    lcd.setCursor(7, 1);
    lcd.print("  ");  // Clear previous number
    lcd.setCursor(7, 1);
    lcd.print(i);
    delay(1000);
  }

  lcd.clear();
  lcd.setCursor(4, 0);
  lcd.print("Dispensing");

  // Move the servo to dispense food
  myservo.write(90);
  delay(1000);
  myservo.write(180);
  delay(1000);
  myservo.write(0);
  delay(1000);

  lcd.clear();
  lcd.setCursor(4, 0);
  lcd.print("Done! :)");

  delay(5000); // Wait 5 seconds before restarting
}
